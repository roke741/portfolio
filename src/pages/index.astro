---
import ContactSection from '../components/astro/sections/ContactSection.astro';
import FooterSection from '../components/astro/sections/FooterSection.astro';
import Header from '../components/astro/sections/Header.astro';
import HeroSection from '../components/astro/sections/HeroSection.astro';
import JourneySection from '../components/astro/sections/JourneySection.astro';
import ProjectsSection from '../components/astro/sections/ProjectsSection.astro';
import SkillsSection from '../components/astro/sections/SkillsSection.astro';
import { ShootingStars } from '../components/react/ui/shooting-stars';
import { StarsBackground } from '../components/react/ui/stars-background';
import TextRokeDevEffect from '../components/react/ui/text-roke-dev-effect';
import Separator from '../components/astro/ui/Separator.astro';
import { contact, footer, header, hero, journey, projects, sectionTitles, seo, skillColumns } from '../data/content';
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout seo={seo}>
	<Header brand={header.brand} navItems={header.navItems} />
	<HeroSection hero={hero} />
	<div class="stars-wrapper">
		<StarsBackground client:load />
		<ShootingStars client:load />
		<div class="stars-wrapper__content">
			<SkillsSection title={sectionTitles.skills} columns={skillColumns} />
			<Separator />
			<ProjectsSection title={sectionTitles.projects} projects={projects} />
			<Separator />
			<JourneySection journey={journey} />
			<Separator />
			<ContactSection contact={contact} />
			<TextRokeDevEffect client:load />
			<FooterSection footer={footer} />
		</div>
	</div>
</MainLayout>

<style>
	.stars-wrapper {
		position: relative;
		width: 100%;
		overflow: hidden;
		background: var(--bg-color);
	}

	.stars-wrapper__content {
		position: relative;
		z-index: 1;
	}

	/* Let the starfield remain visible behind all sections after hero */
	.stars-wrapper :global(section:not(.hero)) {
		background: transparent !important;
	}

	.stars-wrapper :global(section:not(.hero)::before) {
		display: none !important;
	}
</style>
