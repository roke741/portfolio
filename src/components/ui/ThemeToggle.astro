<div class="shadow-button-theme" aria-hidden="true"></div>
<button class="button-theme" type="button" id="theme-toggle" aria-label="Cambiar tema">
  <i class="bi bi-moon-stars" id="theme-icon"></i>
</button>

<script>
  const body = document.body;
  const button = document.getElementById('theme-toggle');
  const icon = document.getElementById('theme-icon');

  const setTheme = (isDark: boolean) => {
    body.classList.toggle('dark-mode', isDark);
    if (icon) {
      icon.className = isDark ? 'bi bi-brightness-high' : 'bi bi-moon-stars';
    }
    localStorage.setItem('darkModeEnabled', JSON.stringify(isDark));
  };

  const isDark = JSON.parse(localStorage.getItem('darkModeEnabled') ?? 'false');
  setTheme(isDark);

  button?.addEventListener('click', () => {
    const current = body.classList.contains('dark-mode');
    setTheme(!current);
  });
</script>

<style>
  .button-theme {
    position: fixed;
    bottom: 70px;
    left: 70px;
    width: 60px;
    height: 60px;
    border: none;
    background: rgba(255, 255, 255, 0.14);
    backdrop-filter: blur(7px);
    -webkit-backdrop-filter: blur(7px);
    color: var(--text-color);
    font-size: 30px;
    transition: 0.5s all;
    cursor: pointer;
    z-index: 100;
  }

  .button-theme:hover {
    transform: translateY(-0.25rem);
    box-shadow: 0 3px 15px rgba(0, 0, 0, 0.2);
  }

  .button-theme:hover:active {
    transform: scale(0.95);
    box-shadow: 3px 2px 22px 1px rgba(0, 0, 0, 0.24);
  }

  .shadow-button-theme {
    position: fixed;
    bottom: 64px;
    left: 75px;
    width: 55px;
    height: 55px;
    border: 3px solid #5163ff;
    z-index: 99;
  }

  @media screen and (max-width: 768px) {
    .button-theme {
      bottom: 24px;
      left: 24px;
    }

    .shadow-button-theme {
      bottom: 18px;
      left: 29px;
    }
  }
</style>
