<script is:inline src="/vendor/liquid-glass/displacement-utils.js"></script>
<script is:inline src="/vendor/liquid-glass/glass-element.js"></script>

<glass-element
  class="liquid-toggle"
  width="60"
  height="60"
  radius="10"
  depth="7"
  blur="0.6"
  strength="50"
  chromatic-aberration="1.1"
  background-color="rgba(255,255,255,0.24)"
  aria-hidden="true"
>
  <button type="button" id="theme-toggle" aria-label="Cambiar tema" class="liquid-toggle-btn">
    <i class="bi bi-moon-stars" id="theme-icon"></i>
  </button>
</glass-element>

<script>
  const body = document.body;
  const button = document.getElementById('theme-toggle');
  const icon = document.getElementById('theme-icon');

  const setTheme = (isDark: boolean) => {
    body.classList.toggle('dark-mode', isDark);
    if (icon) {
      icon.className = isDark ? 'bi bi-brightness-high' : 'bi bi-moon-stars';
    }
    localStorage.setItem('darkModeEnabled', JSON.stringify(isDark));
  };

  const isDark = JSON.parse(localStorage.getItem('darkModeEnabled') ?? 'true');
  setTheme(isDark);

  button?.addEventListener('click', () => {
    const current = body.classList.contains('dark-mode');
    setTheme(!current);
  });
</script>

<style>
  .liquid-toggle {
    position: fixed;
    left: 70px;
    bottom: 70px;
    z-index: 100;
    --glass-padding: 0px;
  }

  .liquid-toggle-btn {
    width: 60px;
    height: 60px;
    border: none;
    border-radius: 20px;
    background: transparent;
    color: var(--text-color);
    font-size: 30px;
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: transform 0.22s ease, filter 0.22s ease;
  }

  .liquid-toggle-btn:hover {
    transform: translateY(-2px) scale(1.01);
    filter: brightness(1.05);
  }

  .liquid-toggle-btn:active {
    transform: scale(0.96);
  }

  @media (prefers-reduced-motion: reduce) {
    .liquid-toggle-btn {
      transition: none;
    }

    .liquid-toggle-btn:hover,
    .liquid-toggle-btn:active {
      transform: none;
      filter: none;
    }
  }

  @media (max-width: 768px) {
    .liquid-toggle {
      left: 20px;
      bottom: 20px;
    }

    .liquid-toggle-btn {
      width: 52px;
      height: 52px;
      border-radius: 17px;
      font-size: 24px;
    }
  }
</style>
