---
import type { ProjectItem } from '../../data/content';

interface Props {
  project: ProjectItem;
}

const { project } = Astro.props;
---

<article class="card-projects">
  <div class="card-project-img">
    <img src={project.image} alt={project.title} loading="lazy" decoding="async" />
  </div>
  <div class="card-project-body">
    <div class="card-project-title">{project.title}</div>
    <div class="card-project-content">
      <div class="decorator"><span class="arrowp2"></span><span class="arrowp1"></span></div>
      <div class="card-project-text">{project.description}</div>
      {project.githubUrl && (
        <div class="card-project-button">
          <a href={project.githubUrl} target="_blank" rel="noopener noreferrer">
            <span>#</span>GitHub
          </a>
        </div>
      )}
      <div class="decorator1"><span class="arrowp2"></span><span class="arrowp1"></span></div>
    </div>
  </div>
</article>

<style>
  .card-projects {
    border: 3px solid var(--border-color);
  }

  .card-project-img img {
    width: 100%;
    border-bottom: 3px solid var(--border-color);
  }

  .card-project-title {
    font-size: 22px;
    font-weight: bold;
    color: #5163ff;
    border-bottom: 3px solid var(--border-color);
    overflow: hidden;
    text-overflow: ellipsis;
    text-align: center;
    padding: 6px;
  }

  .card-project-content {
    padding: 8px;
  }

  .card-project-text {
    padding: 8px 12px;
    font-size: 16px;
    min-height: 65px;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-project-button {
    border: 3px solid #3feb44;
    margin: 13px auto;
    position: relative;
    top: 10px;
    width: max-content;
  }

  .card-project-button a {
    display: inline-block;
    background: #ffffff62;
    backdrop-filter: blur(7px);
    padding: 12px 22px;
    position: relative;
    left: -8px;
    top: -8px;
    color: var(--text-color);
    font-weight: bold;
    font-size: 20px;
    transition: 0.5s all;
    cursor: pointer;
  }

  .card-project-button a span {
    color: #3feb44;
    margin-right: 2px;
  }

  .card-project-button a:hover {
    transform: translateY(-0.25rem);
    box-shadow: 0 3px 15px rgba(0, 0, 0, 0.2);
  }

  .card-project-button a:hover:active {
    transform: scale(0.95);
    box-shadow: 3px 2px 22px 1px rgba(0, 0, 0, 0.24);
  }
</style>
