---
import type { ProjectItem } from '../../data/content';

interface Props {
  project: ProjectItem;
  className?: string;
}

const { project, className = '' } = Astro.props;
const coverImage = project.image ?? '/assets/project-placeholder.svg';
---

<article class={`glass-surface glass-card h-full ${className}`}>
  <div>
    <img
      src={coverImage}
      alt={project.title}
      loading="lazy"
      decoding="async"
      onerror="this.onerror=null;this.src='/assets/project-placeholder.svg';"
      class="glass-card-divider block h-[170px] w-full object-cover"
    />
  </div>
  <div>
    <div
      class="glass-card-divider glass-card-title card-title-block overflow-hidden text-[20px] text-ellipsis max-md:text-[18px]"
    >
      {project.title}
    </div>
    <div class="card-body-block !p-2.5">
      <div class="decorator"><span class="arrowp2"></span><span class="arrowp1"></span></div>
      <div class="glass-card-body min-h-[56px] overflow-hidden px-3 py-1.5 text-[15px] text-ellipsis max-md:text-[14px]">{project.description}</div>
      {project.githubUrl && (
        <div class="frame-accent cta-frame">
          <a
            href={project.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="terminal-action terminal-action-default frame-offset bg-white/40 px-4 py-2 text-[16px] max-md:px-3.5 max-md:py-1.5 max-md:text-[15px]"
          >
            <span class="mr-0.5 text-accent">#</span>GitHub
          </a>
        </div>
      )}
      <div class="decorator1"><span class="arrowp2"></span><span class="arrowp1"></span></div>
    </div>
  </div>
</article>
