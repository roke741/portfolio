---
import type { ProjectItem } from '../../data/content';

interface Props {
  project: ProjectItem;
}

const { project } = Astro.props;
---

<article class="glass-panel-card glass-card">
  <div>
    <img
      src={project.image}
      alt={project.title}
      loading="lazy"
      decoding="async"
      class="glass-card-divider block w-full"
    />
  </div>
  <div>
    <div
      class="glass-card-divider glass-card-title card-title-block overflow-hidden text-[22px] text-ellipsis max-md:text-[19px]"
    >
      {project.title}
    </div>
    <div class="card-body-block">
      <div class="decorator"><span class="arrowp2"></span><span class="arrowp1"></span></div>
      <div class="glass-card-body min-h-[72px] overflow-hidden px-3 py-2 text-base text-ellipsis max-md:text-[15px]">{project.description}</div>
      {project.githubUrl && (
        <div class="frame-accent cta-frame">
          <a
            href={project.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="terminal-action terminal-action-default frame-offset bg-white/40 px-[22px] py-3 text-[20px] max-md:px-[18px] max-md:py-2 max-md:text-[17px]"
          >
            <span class="mr-0.5 text-accent">#</span>GitHub
          </a>
        </div>
      )}
      <div class="decorator1"><span class="arrowp2"></span><span class="arrowp1"></span></div>
    </div>
  </div>
</article>
