---
import type { HeroContent } from '../../data/content';

interface Props {
  hero: HeroContent;
}

const { hero } = Astro.props;
---

<main id="presentation">
  <div class="container-main">
    <section class="main-info">
      <div class="main-bg">
        <div class="decorator"><span class="arrow2"></span><span class="arrow1"></span></div>
        <div class="description">
          <p>{hero.greeting}</p>
          <div class="description-name">
            <h1>{hero.name}</h1>
          </div>
          <div class="description-main">
            <p>{hero.summary}</p>
          </div>
          <div class="btn-container">
            <div class="container-button-cv">
              <div class="bg-button">
                <a class="button-cv" href={hero.ctaHref}><span>#</span>{hero.ctaLabel}</a>
              </div>
            </div>
          </div>
        </div>
        <div class="decorator1"><span class="arrowb1"></span><span class="arrowb2"></span></div>
      </div>
    </section>
    <section class="main-img">
      <div>
        <img src={hero.imageSrc} alt={hero.imageAlt} loading="eager" decoding="async" />
      </div>
    </section>
  </div>
</main>

<style>
  main {
    width: 100%;
  }

  .container-main {
    padding: 20px;
    margin: 80px auto;
    display: flex;
    max-width: 1350px;
    gap: 40px;
  }

  .main-info,
  .main-img {
    width: 50%;
  }

  .main-bg {
    max-width: 600px;
    height: 100%;
    margin: auto;
    padding: 30px;
    background: #ffffff24;
    backdrop-filter: blur(7px);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    box-shadow: 0 0 10px #0000001f;
  }

  .arrow1 {
    height: 120px;
    width: 4px;
    background-color: #5163ff;
    position: absolute;
  }

  .arrow2,
  .arrowb1 {
    height: 4px;
    width: 120px;
    background-color: #5163ff;
  }

  .arrowb2 {
    height: 120px;
    width: 4px;
    background-color: #5163ff;
    position: absolute;
  }

  .description {
    text-align: center;
    display: flex;
    flex-direction: column;
    padding: 10px;
    font-size: 20px;
  }

  .description-name h1 {
    color: #5163ff;
    font-size: 3rem;
    margin: 0;
  }

  .description-main p {
    font-size: 1.2rem;
    margin: 0;
  }

  .btn-container {
    width: 100%;
    display: flex;
    justify-content: center;
    margin-top: 65px;
  }

  .container-button-cv {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bg-button {
    border: 3px solid #3feb44;
    display: flex;
    justify-content: center;
  }

  .button-cv {
    background: #ffffff24;
    backdrop-filter: blur(7px);
    align-items: center;
    padding: 20px 35px;
    position: relative;
    top: -10px;
    right: 10px;
    cursor: pointer;
    transition: all 0.5s ease;
    font-size: 18px;
    font-weight: bold;
  }

  .button-cv span {
    color: #3feb44;
    margin-right: 2px;
  }

  .button-cv:hover {
    transform: translateY(-0.25rem);
    box-shadow: 0 3px 15px rgba(0, 0, 0, 0.2);
  }

  .button-cv:hover:active {
    transform: scale(0.95);
    box-shadow: 3px 2px 22px 1px rgba(0, 0, 0, 0.24);
  }

  .main-img {
    text-align: center;
  }

  .main-img img {
    max-width: 100%;
    height: auto;
  }

  @media screen and (max-width: 845px) {
    .container-main {
      flex-direction: column;
      align-items: center;
      margin: 20px auto;
      padding: 20px;
    }

    .main-info,
    .main-img {
      width: 100%;
    }

    .description {
      font-size: 14px;
    }

    .description-main p {
      font-size: 0.9rem;
    }
  }

  @media screen and (max-width: 1245px) {
    .container-main {
      padding: 20px 70px;
    }

    .main-bg {
      padding: 20px;
    }

    .description {
      font-size: 18px;
    }

    .description-name h1 {
      font-size: 2.2rem;
    }

    .description-main p {
      font-size: 0.9rem;
    }

    .btn-container {
      margin-top: 35px;
    }

    .button-cv {
      font-size: 14px;
    }
  }
</style>
