---
import type { HeroContent } from '../../data/content';

interface Props {
  hero: HeroContent;
}

const { hero } = Astro.props;
---

<main id="presentation">
  <div class="page-container section-shell my-0 flex gap-10 max-[1245px]:px-10 max-[845px]:flex-col max-[845px]:items-center max-[845px]:gap-6 max-[845px]:py-4">
    <section class="w-1/2 max-[845px]:w-full">
      <div class="glass-surface mx-auto flex max-w-150 flex-col p-8 max-[1245px]:p-5">
        <div class="decorator"><span class="h-1 w-30 bg-primary"></span><span class="absolute h-30 w-1 bg-primary"></span></div>
        <div class="flex flex-col p-2.5 text-center text-[20px] max-[1245px]:text-[18px] max-[845px]:text-[13px]">
          <p>{hero.greeting}</p>
          <div>
            <h1 class="m-0 text-5xl font-extrabold text-primary drop-shadow-[0_0_18px_rgba(81,99,255,0.55)] max-[1245px]:text-[2.2rem] max-[845px]:text-[1.85rem]">{hero.name}</h1>
          </div>
          <div>
            <p class="m-0 text-[1.2rem] max-[1245px]:text-[0.9rem] max-[845px]:text-[0.9rem]">{hero.summary}</p>
          </div>
          <div class="mt-6 flex w-full justify-center max-[1245px]:mt-4">
            <div class="flex flex-1 items-center justify-center">
              <div class="frame-accent flex justify-center">
                <a
                  class="terminal-action terminal-action-default relative -right-2.5 -top-2.5 bg-white/15 px-8 py-4 text-lg max-[1245px]:text-sm max-[845px]:px-6 max-[845px]:py-3"
                  href={hero.ctaHref}
                ><span class="mr-0.5 text-accent">#</span>{hero.ctaLabel}</a
                >
              </div>
            </div>
          </div>
        </div>
        <div class="decorator1"><span class="h-1 w-30 bg-primary"></span><span class="absolute h-30 w-1 bg-primary"></span></div>
      </div>
    </section>
    <section class="w-1/2 text-center max-[845px]:w-full">
      <div>
        <img src={hero.imageSrc} alt={hero.imageAlt} loading="eager" decoding="async" class="h-auto max-w-full" />
      </div>
    </section>
  </div>
</main>
