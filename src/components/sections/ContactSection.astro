---
import type { ContactContent } from '../../data/content';
import SectionTitle from '../ui/SectionTitle.astro';

interface Props {
  contact: ContactContent;
}

const { contact } = Astro.props;
---

<section id="contact">
  <div class="page-container section-shell section-stack w-full">
    <SectionTitle text={contact.title} />
    <div class="glass-panel-soft elevated-panel mx-auto max-w-[1200px] p-6 max-md:p-4">
      <div class="decorator"><span class="arrowp2"></span><span class="arrowp1"></span></div>
      <form action="#" method="post" class="mx-4 my-2 max-md:mx-1.5 max-md:my-1">
        <div class="flex gap-6 max-md:block">
          <div class="flex w-1/4 flex-col max-md:mb-5 max-md:w-full">
            <label for="name">{contact.nameLabel}</label>
            <input
              id="name"
              name="name"
              type="text"
              class="soft-input h-11 px-4"
            />
            <label for="email" class="mt-4">{contact.emailLabel}</label>
            <input
              id="email"
              name="email"
              type="email"
              class="soft-input h-11 px-4"
            />
          </div>
          <div class="flex w-3/4 flex-col max-md:h-[200px] max-md:w-full">
            <label for="message">{contact.messageLabel}</label>
            <textarea
              id="message"
              name="message"
              placeholder={contact.messagePlaceholder}
              class="soft-input h-full w-full resize-none px-4 py-2 text-base"
            ></textarea>
          </div>
        </div>
        <div class="frame-accent cta-frame">
          <button
            type="submit"
            class="terminal-action terminal-action-soft frame-offset border-none bg-white/40 px-[22px] py-3 text-[20px] max-md:px-[18px] max-md:py-2 max-md:text-[17px]"
          ><span class="mr-0.5 text-accent">#</span>{contact.submitLabel}</button
          >
        </div>
      </form>
      <div class="decorator1"><span class="arrowp1"></span><span class="arrowp2"></span></div>
    </div>
  </div>
</section>
