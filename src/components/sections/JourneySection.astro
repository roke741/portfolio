---
import type { JourneyContent } from '../../data/content';
import SectionTitle from '../ui/SectionTitle.astro';

interface Props {
  journey: JourneyContent;
}

const { journey } = Astro.props;
---

<section id="journey">
  <div class="page-container section-shell section-stack">
    <SectionTitle text={journey.title} />

    <div class="grid w-full max-w-[1080px] grid-cols-1 gap-4 lg:grid-cols-2 lg:gap-6">
      <div class="space-y-4">
        <div class="mb-1 flex items-center gap-3">
          <span class="h-[2px] w-10 bg-primary"></span>
          <h3 class="m-0 text-xl md:text-2xl">{journey.experienceTitle}</h3>
        </div>
        <div class="space-y-4">
          {journey.experience.map((item) => (
            <article class="glass-surface p-4 md:p-5">
              <div class="mb-2 inline-flex rounded-full border border-primary/50 bg-primary/10 px-3 py-1 text-xs font-semibold tracking-wide text-primary">
                {item.period}
              </div>
              <h3 class="m-0 text-[18px] md:text-[20px]">{item.title}</h3>
              <p class="m-0 text-sm font-semibold text-accent">{item.organization}</p>
              <p class="mt-2 text-sm leading-6 text-[var(--card-muted-color)] md:text-[15px]">{item.summary}</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {item.tags.map((tag) => (
                  <span class="rounded-md border border-white/20 bg-white/5 px-2 py-1 text-xs text-[var(--card-muted-color)]">#{tag}</span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="space-y-4">
        <div class="mb-1 flex items-center gap-3">
          <span class="h-[2px] w-10 bg-accent"></span>
          <h3 class="m-0 text-xl md:text-2xl">{journey.educationTitle}</h3>
        </div>
        <div class="space-y-4">
          {journey.education.map((item) => (
            <article class="glass-surface p-4 md:p-5">
              <div class="mb-2 inline-flex rounded-full border border-primary/50 bg-primary/10 px-3 py-1 text-xs font-semibold tracking-wide text-primary">
                {item.period}
              </div>
              <h3 class="m-0 text-[18px] md:text-[20px]">{item.title}</h3>
              <p class="m-0 text-sm font-semibold text-accent">{item.organization}</p>
              <p class="mt-2 text-sm leading-6 text-[var(--card-muted-color)] md:text-[15px]">{item.summary}</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {item.tags.map((tag) => (
                  <span class="rounded-md border border-white/20 bg-white/5 px-2 py-1 text-xs text-[var(--card-muted-color)]">#{tag}</span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
