---
import type { SkillCard } from '../../data/content';
import SkillCards from '../ui/SkillCards.astro';
import SectionTitle from '../ui/SectionTitle.astro';

interface Props {
  title: string;
  columns: SkillCard[][];
}

const { title, columns } = Astro.props;
---

<section id="skills">
  <div class="page-container section-shell section-stack">
    <SectionTitle text={title} />
    <div class="flex w-full items-center justify-center gap-8 p-4 max-[1100px]:gap-6 max-[845px]:flex-col max-[845px]:p-2">
      <SkillCards columns={columns} />
      <aside id="techSphere" class="tech-sphere" aria-label="Esfera 3D de tecnologías">
        <div id="techSphereCanvas" class="tech-sphere__canvas"></div>
        <p class="tech-sphere__hint">
          <span class="tech-sphere__dot"></span> Arrastra para rotar &nbsp;
          <span class="tech-sphere__dot"></span> Scroll para zoom &nbsp;
          <span class="tech-sphere__dot"></span> Click para explotar
        </p>
      </aside>
    </div>
  </div>
</section>

<script>
  import * as THREE from 'three';

  /* ── Configuración ─────────────────────────────────────────────── */
  const TECH_ICONS = [
    'python', 'javascript', 'typescript', 'java', 'php', 'angular',
    'react', 'spring', 'nodejs', 'mysql', 'postgresql', 'mongodb',
    'docker', 'git',
  ];
  const ICON_BASE   = '/assets/tech/';
  const SPHERE_SEG  = 48;
  const ICON_RADIUS = 1.38;
  const ICON_SCALE  = 0.30;
  const CAM_Z_INIT  = 3.6;
  const CAM_Z_MIN   = 2.0;
  const CAM_Z_MAX   = 5.5;

  /* ── Helpers ───────────────────────────────────────────────────── */

  /** Distribuye N puntos uniformemente en una esfera (Fibonacci) */
  function fibSpherePoints(n: number, radius: number): THREE.Vector3[] {
    const pts: THREE.Vector3[] = [];
    const golden = Math.PI * (3 - Math.sqrt(5));
    for (let i = 0; i < n; i++) {
      const y = 1 - (i / (n - 1)) * 2;
      const r = Math.sqrt(1 - y * y);
      const θ = golden * i;
      pts.push(new THREE.Vector3(Math.cos(θ) * r * radius, y * radius, Math.sin(θ) * r * radius));
    }
    return pts;
  }

  /** Carga un SVG → CanvasTexture (fetch → blob → canvas) */
  async function svgToTexture(url: string, size = 128): Promise<THREE.CanvasTexture | null> {
    try {
      let text = await (await fetch(url)).text();

      // Agregar width/height explícitos si faltan para que <img> tenga tamaño intrínseco
      if (!text.includes('width=')) {
        text = text.replace('<svg ', `<svg width="${size}" height="${size}" `);
      }

      const blob = new Blob([text], { type: 'image/svg+xml;charset=utf-8' });
      const blobUrl = URL.createObjectURL(blob);

      return await new Promise<THREE.CanvasTexture | null>((resolve) => {
        const img = new Image();
        img.onload = () => {
          const c = document.createElement('canvas');
          c.width = c.height = size;
          const ctx = c.getContext('2d')!;

          // Fondo circular semi-transparente detrás del ícono
          ctx.beginPath();
          ctx.arc(size / 2, size / 2, size / 2 - 2, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(22, 28, 42, 0.55)';
          ctx.fill();
          ctx.strokeStyle = 'rgba(81, 99, 255, 0.35)';
          ctx.lineWidth = 2;
          ctx.stroke();

          // Dibujar el ícono centrado con padding
          const pad = size * 0.22;
          const area = size - pad * 2;
          const nw = img.naturalWidth || size;
          const nh = img.naturalHeight || size;
          const ratio = Math.min(area / nw, area / nh);
          const w = nw * ratio;
          const h = nh * ratio;
          ctx.drawImage(img, (size - w) / 2, (size - h) / 2, w, h);

          URL.revokeObjectURL(blobUrl);
          const tex = new THREE.CanvasTexture(c);
          tex.colorSpace = THREE.SRGBColorSpace;
          tex.needsUpdate = true;
          resolve(tex);
        };
        img.onerror = () => { URL.revokeObjectURL(blobUrl); resolve(null); };
        img.src = blobUrl;
      });
    } catch { return null; }
  }

  /* ── Boot ──────────────────────────────────────────────────────── */
  function bootSphere() {
    const wrapper   = document.getElementById('techSphere');
    const container = document.getElementById('techSphereCanvas');
    if (!wrapper || !container) return;

    const getSize = () => ({ w: container.clientWidth || 420, h: container.clientHeight || 420 });
    let { w: W, h: H } = getSize();

    /* Scene */
    const scene    = new THREE.Scene();
    const camera   = new THREE.PerspectiveCamera(55, W / H, 0.1, 100);
    camera.position.z = CAM_Z_INIT;

    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setSize(W, H);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0);
    container.appendChild(renderer.domElement);

    const root = new THREE.Group();
    scene.add(root);

    /* Luces */
    scene.add(new THREE.AmbientLight(0xffffff, 0.4));
    const key = new THREE.DirectionalLight(0x8ea0ff, 1.2);
    key.position.set(2, 3, 3);
    scene.add(key);

    /* ── Wireframe sphere ── */
    const sphereGeo = new THREE.IcosahedronGeometry(1, 3);
    const wireMat   = new THREE.MeshBasicMaterial({
      color: 0x5163ff, wireframe: true, transparent: true, opacity: 0.18,
    });
    const wireMesh  = new THREE.Mesh(sphereGeo, wireMat);
    root.add(wireMesh);

    /* ── Puntos en la superficie ── */
    const dotCount = 600;
    const dotPos   = new Float32Array(dotCount * 3);
    for (let i = 0; i < dotCount; i++) {
      const φ = Math.acos(2 * Math.random() - 1);
      const θ = Math.random() * Math.PI * 2;
      dotPos[i * 3]     = Math.sin(φ) * Math.cos(θ) * 1.01;
      dotPos[i * 3 + 1] = Math.sin(φ) * Math.sin(θ) * 1.01;
      dotPos[i * 3 + 2] = Math.cos(φ) * 1.01;
    }
    const dotGeo = new THREE.BufferGeometry();
    dotGeo.setAttribute('position', new THREE.BufferAttribute(dotPos, 3));
    root.add(new THREE.Points(dotGeo, new THREE.PointsMaterial({
      color: 0x5163ff, size: 0.012, transparent: true, opacity: 0.45, sizeAttenuation: true,
    })));

    /* ── Halo exterior ── */
    root.add(new THREE.Mesh(
      new THREE.IcosahedronGeometry(1.12, 2),
      new THREE.MeshBasicMaterial({ color: 0x5163ff, transparent: true, opacity: 0.06, side: THREE.BackSide })
    ));

    /* ── Íconos de tecnologías (sprites) ── */
    const iconGroup   = new THREE.Group();
    const iconSprites: THREE.Sprite[] = [];
    const iconOrigins  = fibSpherePoints(TECH_ICONS.length, ICON_RADIUS);
    const scatterDirs: THREE.Vector3[] = [];

    root.add(iconGroup);

    for (let i = 0; i < TECH_ICONS.length; i++) {
      const mat = new THREE.SpriteMaterial({ transparent: true, depthWrite: false, opacity: 0 });
      const sprite = new THREE.Sprite(mat);
      sprite.position.copy(iconOrigins[i]);
      sprite.scale.setScalar(ICON_SCALE);
      iconGroup.add(sprite);
      iconSprites.push(sprite);
      scatterDirs.push(iconOrigins[i].clone().normalize().multiplyScalar(Math.random() * 0.8 + 0.6));
    }

    // Cargar texturas en paralelo
    Promise.all(TECH_ICONS.map((name, i) =>
      svgToTexture(`${ICON_BASE}${name}.svg`).then((tex) => {
        if (tex) {
          iconSprites[i].material.map = tex;
          iconSprites[i].material.opacity = 1;
          iconSprites[i].material.needsUpdate = true;
        }
      })
    ));

    /* ── Líneas de conexión entre íconos vecinos ── */
    const linePoints: number[] = [];
    for (let i = 0; i < iconOrigins.length; i++) {
      for (let j = i + 1; j < iconOrigins.length; j++) {
        if (iconOrigins[i].distanceTo(iconOrigins[j]) < ICON_RADIUS * 1.15) {
          linePoints.push(
            iconOrigins[i].x, iconOrigins[i].y, iconOrigins[i].z,
            iconOrigins[j].x, iconOrigins[j].y, iconOrigins[j].z,
          );
        }
      }
    }
    if (linePoints.length) {
      const lineGeo = new THREE.BufferGeometry();
      lineGeo.setAttribute('position', new THREE.Float32BufferAttribute(linePoints, 3));
      iconGroup.add(new THREE.LineSegments(lineGeo, new THREE.LineBasicMaterial({
        color: 0x5163ff, transparent: true, opacity: 0.12,
      })));
    }

    /* ── Interacción: mouse / drag ── */
    let mouseX = 0, mouseY = 0;
    let targetRotX = 0, targetRotY = 0;
    let isDragging = false;
    let prevDrag = { x: 0, y: 0 };
    let dragRotX = 0, dragRotY = 0;

    container.addEventListener('pointerdown', (e) => {
      isDragging = true;
      prevDrag = { x: e.clientX, y: e.clientY };
      container.setPointerCapture(e.pointerId);
    });
    container.addEventListener('pointermove', (e) => {
      const rect = container.getBoundingClientRect();
      mouseX = ((e.clientX - rect.left) / rect.width) * 2 - 1;
      mouseY = -((e.clientY - rect.top) / rect.height) * 2 + 1;
      if (isDragging) {
        dragRotY += (e.clientX - prevDrag.x) * 0.008;
        dragRotX += (e.clientY - prevDrag.y) * 0.008;
        prevDrag = { x: e.clientX, y: e.clientY };
      }
    });
    container.addEventListener('pointerup', () => { isDragging = false; });

    /* ── Explosión al click ── */
    let exploding = false, explodeT = 0;
    container.addEventListener('click', (e) => {
      if (Math.abs(dragRotX) < 0.02 && Math.abs(dragRotY) < 0.02 || !isDragging) {
        exploding = true;
        explodeT = 0;
      }
    });

    /* ── Scroll zoom ── */
    container.addEventListener('wheel', (e) => {
      e.preventDefault();
      camera.position.z = Math.max(CAM_Z_MIN, Math.min(CAM_Z_MAX, camera.position.z + e.deltaY * 0.003));
    }, { passive: false });

    /* ── Resize ── */
    window.addEventListener('resize', () => {
      const { w, h } = getSize();
      W = w; H = h;
      camera.aspect = W / H;
      camera.updateProjectionMatrix();
      renderer.setSize(W, H);
    }, { passive: true });

    /* ── Render loop ── */
    const clock = new THREE.Clock();
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    (function animate() {
      requestAnimationFrame(animate);
      const t = clock.getElapsedTime();

      // Rotación auto + mouse + drag
      if (!reducedMotion) {
        targetRotY += (mouseX * 0.6 - targetRotY) * 0.03;
        targetRotX += (-mouseY * 0.4 - targetRotX) * 0.03;
      }
      root.rotation.y = dragRotY + targetRotY + t * 0.12;
      root.rotation.x = dragRotX + targetRotX;

      // Breathing
      if (!reducedMotion && !exploding) {
        const b = 1 + Math.sin(t * 0.7) * 0.02;
        wireMesh.scale.setScalar(b);
      }

      // Explosión de íconos
      if (exploding) {
        explodeT += 0.035;
        const ease = Math.sin(Math.min(explodeT, Math.PI));
        for (let i = 0; i < iconSprites.length; i++) {
          const o = iconOrigins[i];
          const d = scatterDirs[i];
          iconSprites[i].position.set(
            o.x + d.x * ease * 1.2,
            o.y + d.y * ease * 1.2,
            o.z + d.z * ease * 1.2,
          );
        }
        if (explodeT >= Math.PI) {
          exploding = false;
          for (let i = 0; i < iconSprites.length; i++) {
            iconSprites[i].position.copy(iconOrigins[i]);
          }
        }
      }

      renderer.render(scene, camera);
    })();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bootSphere);
  } else {
    bootSphere();
  }
</script>
