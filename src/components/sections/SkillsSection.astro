---
import type { SkillCard } from '../../data/content';
import SkillCards from '../ui/SkillCards.astro';
import SectionTitle from '../ui/SectionTitle.astro';

interface Props {
  title: string;
  columns: SkillCard[][];
  imageSrc: string;
  imageAlt: string;
}

const { title, columns, imageSrc, imageAlt } = Astro.props;
---

<section id="skills">
  <div class="page-container section-shell section-stack">
    <SectionTitle text={title} />
    <div class="flex w-full items-start gap-8 p-4 max-[845px]:block max-[845px]:p-2">
      <SkillCards columns={columns} />
      <div class="max-[845px]:max-w-[650px]">
        <img
          src={imageSrc}
          alt={imageAlt}
          loading="lazy"
          decoding="async"
          class="h-auto max-w-full max-[845px]:box-border max-[845px]:w-full max-[845px]:p-3"
        />
      </div>
    </div>
  </div>
</section>
