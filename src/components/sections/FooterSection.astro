---
import type { FooterContent } from '../../data/content';

interface Props {
  footer: FooterContent;
}

const { footer } = Astro.props;
---

<footer>
  <div class="page-container section-shell !pt-0">
    <div class="glass-panel-soft elevated-panel text-center text-[18px] max-md:text-[15px]">
      <div class="grid grid-cols-3 gap-6 p-5 max-md:grid-cols-1 max-md:gap-4 max-md:p-3">
      <div>
        {footer.name}<br />
        {footer.roles.map((role) => (
          <>
            {role}
            <br />
          </>
        ))}
      </div>
      <div>
        Correo: <br />
        <a href={`mailto:${footer.email}`}>{footer.email}</a>
      </div>
      <div>
        <div>
          {footer.socialLinks.map((social) => (
            <a href={social.href} aria-label={social.label} target="_blank" rel="noopener noreferrer">
              <i class={`bi ${social.icon} px-2.5 text-[34px] max-md:px-2 max-md:text-[27px]`}></i>
            </a>
          ))}
        </div>
      </div>
      <hr class="h-1 border-none bg-primary" />
      <div class="p-5 max-md:px-3 max-md:py-4">
        <div>
          {footer.signature}<br />
          {footer.copyright}
        </div>
      </div>
    </div>
  </div>
</footer>
