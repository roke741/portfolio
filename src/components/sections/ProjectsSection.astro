---
import type { ProjectItem } from '../../data/content';
import ProjectCard from '../ui/ProjectCard.astro';
import SectionTitle from '../ui/SectionTitle.astro';

interface Props {
  title: string;
  projects: ProjectItem[];
}

const { title, projects } = Astro.props;
---

<section id="projects">
  <div class="page-container section-shell section-stack">
    <SectionTitle text={title} />
    <div class="mx-auto grid w-full max-w-[1240px] grid-cols-3 gap-6 max-md:max-w-[620px] max-md:grid-cols-1 max-md:box-border max-md:gap-5 max-md:px-2 max-md:py-4">
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </div>
</section>
