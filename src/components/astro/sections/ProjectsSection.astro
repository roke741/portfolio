---
import type { ProjectItem } from '@/data/content';
import ProjectCard from '@/components/astro/ui/ProjectCard.astro';
import SectionTitle from '@/components/astro/ui/SectionTitle.astro';

interface Props {
  title: string;
  projects: ProjectItem[];
}

const { title, projects } = Astro.props;

type CardConfig = { colSpanClass: string; heightClass: string };

function getCardConfig(index: number, total: number): CardConfig {
  // Lone final item in an odd-length list → full-width banner
  if (index === total - 1 && total % 2 !== 0) {
    return {
      colSpanClass: 'md:col-span-12',
      heightClass:  'h-[220px] md:h-[280px]',
    };
  }
  // Alternating row rhythm: even rows → [large 7, small 5],  odd rows → [small 5, large 7]
  const row       = Math.floor(index / 2);
  const posInRow  = index % 2;
  const isEvenRow = row % 2 === 0;
  const isLarge   = isEvenRow ? posInRow === 0 : posInRow === 1;
  return {
    colSpanClass: isLarge ? 'md:col-span-7' : 'md:col-span-5',
    heightClass:  'h-[300px] md:h-[380px]',
  };
}
---

<section id="projects">
  <div class="page-container section-shell section-stack">
    <SectionTitle text={title} />
    <div
      id="projects-grid"
      class="mx-auto grid w-full max-w-270 grid-cols-1 gap-4 md:grid-cols-12 md:gap-5"
    >
      {projects.map((project, i) => {
        const { colSpanClass, heightClass } = getCardConfig(i, projects.length);
        return (
          <ProjectCard
            project={project}
            index={i}
            colSpanClass={colSpanClass}
            heightClass={heightClass}
          />
        );
      })}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)'
  ).matches;

  if (!prefersReducedMotion) {
    const cards = gsap.utils.toArray<HTMLElement>('[data-project-card]');

    // ── Scroll entrance: staggered fade + rise ──────────────────────────
    if (cards.length) {
      gsap.from(cards, {
        scrollTrigger: {
          trigger: '#projects-grid',
          start: 'top 82%',
        },
        opacity: 0,
        y: 42,
        scale: 0.97,
        duration: 0.82,
        stagger: 0.1,
        ease: 'power3.out',
        clearProps: 'all',
      });
    }

    // ── Magnetic lift: GSAP handles the overall card translateY ─────────
    cards.forEach((card) => {
      card.addEventListener('mouseenter', () =>
        gsap.to(card, { y: -7, duration: 0.32, ease: 'power2.out',
          boxShadow: '0 28px 60px rgba(4,10,24,0.72)' })
      );
      card.addEventListener('mouseleave', () =>
        gsap.to(card, { y: 0, duration: 0.42, ease: 'power2.inOut',
          boxShadow: '0 0px 0px rgba(4,10,24,0)' })
      );
    });
  }
</script>
