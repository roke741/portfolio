---
import type { ContactContent } from "@/data/content";
import SectionTitle from "@/components/astro/ui/SectionTitle.astro";
import { Send } from '@lucide/astro';

interface Props {
  contact: ContactContent;
  email?: string;
  githubUrl?: string;
  linkedinUrl?: string;
}

const { contact, email, githubUrl, linkedinUrl } = Astro.props;
const mailtoHref = email ? `mailto:${email}` : null;
---

<section id="contact" class="relative overflow-hidden" data-contact-section>

  <!-- Ambient glow blobs (parallax) -->
  <div class="pointer-events-none absolute inset-0 z-0" aria-hidden="true">
    <div
      class="contact-blob-1 absolute -top-32 left-[10%] h-[420px] w-[420px] rounded-full blur-3xl"
      style="background: radial-gradient(circle, rgba(123,142,200,0.07) 0%, transparent 68%);"
    ></div>
    <div
      class="contact-blob-2 absolute -bottom-16 right-[6%] h-96 w-96 rounded-full blur-3xl"
      style="background: radial-gradient(circle, rgba(52,199,89,0.05) 0%, transparent 68%);"
    ></div>
  </div>

  <!-- Main content -->
  <div class="page-container section-shell section-stack relative z-10">

    <!-- Section header -->
    <div data-contact-el="header" style="opacity:0; transform:translateY(26px);">
      <SectionTitle text={contact.title} />
    </div>

    <!-- CTA message -->
    <div
      data-contact-el="cta"
      class="mx-auto max-w-lg text-center"
      style="opacity:0; transform:translateY(22px);"
    >
      <p class="m-0 text-[clamp(1rem,2.2vw,1.2rem)] leading-[1.8] text-white/38">
        ¿Tienes un proyecto en mente?<br />
        <span class="text-white/58 font-medium">Construyamos algo significativo juntos.</span>
      </p>
    </div>

    <!-- Contact card -->
    <div
      data-contact-el="card"
      class="mx-auto flex w-full max-w-245 justify-center"
      style="opacity:0; transform:translateY(28px);"
    >
      <div
        class="contact-card relative w-full overflow-hidden rounded-3xl border border-primary/25 bg-[linear-gradient(160deg,rgba(10,18,40,0.98),rgba(8,16,36,0.94))] p-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.06),0_30px_65px_rgba(2,8,24,0.55)] backdrop-blur-md md:p-9"
      >
        <!-- Inner ambient gradients (float via GSAP) -->
        <div class="contact-inner-ambient pointer-events-none absolute inset-0" aria-hidden="true">
          <div class="absolute -top-16 -left-16 h-72 w-72 rounded-full bg-[radial-gradient(circle,rgba(123,142,200,0.09)_0%,transparent_70%)] blur-2xl"></div>
          <div class="absolute -bottom-16 -right-16 h-72 w-72 rounded-full bg-[radial-gradient(circle,rgba(52,199,89,0.06)_0%,transparent_70%)] blur-2xl"></div>
        </div>

        <!-- Success overlay (shown after submit) -->
        <div
          id="contact-success"
          class="pointer-events-none absolute inset-0 z-20 flex flex-col items-center justify-center gap-3 rounded-3xl bg-[rgba(4,10,24,0.9)] opacity-0 backdrop-blur-sm"
          aria-live="polite"
          aria-atomic="true"
        >
          <span class="text-5xl" aria-hidden="true">🚀</span>
          <p class="m-0 text-center text-[1.15rem] font-semibold text-white/92">
            ¡Mensaje enviado con éxito!
          </p>
          <p class="m-0 text-center text-sm text-white/45">
            Me pondré en contacto contigo pronto.
          </p>
        </div>

        <form id="contact-form" action="#" method="post" class="relative z-10 w-full" novalidate>
          <div class="grid w-full grid-cols-1 gap-6 md:grid-cols-[1fr_1.12fr] md:gap-7">

            <!-- Left: name + email -->
            <div class="flex flex-col gap-5 md:pt-0.5">
              <div class="contact-field flex flex-col gap-2">
                <label
                  for="contact-name"
                  class="contact-label text-[0.9rem] font-medium tracking-[0.01em] text-white/65 transition-colors duration-200"
                >{contact.nameLabel}</label>
                <input
                  id="contact-name"
                  name="name"
                  type="text"
                  placeholder="Tu nombre"
                  class="input-shell h-12 px-4"
                  autocomplete="name"
                  required
                />
              </div>

              <div class="contact-field flex flex-col gap-2">
                <label
                  for="contact-email"
                  class="contact-label text-[0.9rem] font-medium tracking-[0.01em] text-white/65 transition-colors duration-200"
                >{contact.emailLabel}</label>
                <input
                  id="contact-email"
                  name="email"
                  type="email"
                  placeholder="tu@correo.com"
                  class="input-shell h-12 px-4"
                  autocomplete="email"
                  required
                />
              </div>
            </div>

            <!-- Right: message -->
            <div class="contact-field flex flex-col gap-2">
              <label
                for="contact-message"
                class="contact-label text-[0.9rem] font-medium tracking-[0.01em] text-white/65 transition-colors duration-200"
              >{contact.messageLabel}</label>
              <textarea
                id="contact-message"
                name="message"
                placeholder={contact.messagePlaceholder}
                class="input-shell min-h-43 flex-1 resize-none px-4 py-3.5 md:min-h-40"
                required
              ></textarea>
            </div>
          </div>

          <!-- Footer row -->
          <div class="mt-7 flex items-center justify-between gap-4 max-md:flex-col max-md:items-stretch">
            <p class="text-xs text-white/38 max-md:text-center">Respuesta en 24h hábiles.</p>

            <button
              id="contact-submit"
              type="submit"
              class="contact-btn btn-primary group relative min-h-12 min-w-47.5 overflow-hidden px-8 py-3 max-md:w-full"
            >
              <!-- Gradient glow layer -->
              <span
                class="absolute inset-0 rounded-xl bg-gradient-to-r from-primary/30 via-primary/10 to-accent/20 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
                aria-hidden="true"
              ></span>
              <!-- Default label -->
              <span id="contact-btn-default" class="relative flex items-center justify-center gap-2">
                <Send size={16} stroke-width={2} aria-hidden="true" />
                {contact.submitLabel}
              </span>
              <!-- Loading label -->
              <span id="contact-btn-loading" class="relative hidden items-center justify-center gap-2">
                <span class="contact-spinner h-[15px] w-[15px] shrink-0 rounded-full border-2 border-white/25 border-t-white"></span>
                Enviando…
              </span>
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Social links -->
    <div
      data-contact-el="socials"
      class="flex flex-wrap items-center justify-center gap-3"
      style="opacity:0; transform:translateY(18px);"
    >
      <span class="text-[11px] uppercase tracking-[0.14em] text-white/25">o encuéntrame en</span>

      {githubUrl && githubUrl !== '#' && (
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="contact-social btn-icon"
        >
          <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"/>
          </svg>
        </a>
      )}

      {linkedinUrl && linkedinUrl !== '#' && (
        <a
          href={linkedinUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="contact-social btn-icon"
        >
          <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286ZM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065Zm1.782 13.019H3.555V9h3.564v11.452ZM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003Z"/>
          </svg>
        </a>
      )}

      {mailtoHref && (
        <a
          href={mailtoHref}
          aria-label="Correo electrónico"
          class="contact-social btn-icon"
        >
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
        </a>
      )}
    </div>

  </div>
</section>

<style>
  /* ── Submit spinner ──────────────────────────────────────── */
  @keyframes contact-spin {
    to { transform: rotate(360deg); }
  }
  .contact-spinner {
    display: inline-block;
    animation: contact-spin 0.72s linear infinite;
  }

  /* ── Label accent on focus ───────────────────────────────── */
  .contact-label.is-focused {
    color: rgba(123, 142, 200, 0.88);
  }

  /* ── Social icon hover lift ──────────────────────────────── */
  .contact-social {
    transition: transform 0.22s ease, border-color 0.22s ease, color 0.22s ease;
  }
  .contact-social:hover {
    transform: translateY(-3px);
    border-color: rgba(123, 142, 200, 0.42);
    color: rgba(123, 142, 200, 0.9);
  }

  /* ── Card smooth border/shadow transitions for GSAP hover ── */
  .contact-card {
    transition: border-color 0.28s ease;
  }

  /* ── Reduced-motion: kill marquee ───────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .contact-spinner { animation: none; border-top-color: white; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)'
  ).matches;

  const els = [
    document.querySelector<HTMLElement>('[data-contact-el="header"]'),
    document.querySelector<HTMLElement>('[data-contact-el="cta"]'),
    document.querySelector<HTMLElement>('[data-contact-el="card"]'),
    document.querySelector<HTMLElement>('[data-contact-el="socials"]'),
  ].filter(Boolean) as HTMLElement[];

  if (prefersReducedMotion) {
    els.forEach((el) => { el.style.opacity = '1'; el.style.transform = 'none'; });
  } else {
    // ── Sequential scroll stagger ────────────────────────────
    els.forEach((el, i) => {
      gsap.to(el, {
        scrollTrigger: { trigger: '#contact', start: 'top 80%' },
        opacity: 1,
        y: 0,
        duration: 0.85,
        delay: i * 0.15,
        ease: 'power3.out',
        clearProps: 'will-change',
      });
    });

    // ── Ambient blob parallax ────────────────────────────────
    [
      { sel: '.contact-blob-1', rate: -0.1 },
      { sel: '.contact-blob-2', rate:  0.08 },
    ].forEach(({ sel, rate }) => {
      const el = document.querySelector<HTMLElement>(sel);
      const section = document.querySelector<HTMLElement>('#contact');
      if (!el || !section) return;
      gsap.to(el, {
        scrollTrigger: { trigger: section, start: 'top bottom', end: 'bottom top', scrub: 2 },
        y: () => section.offsetHeight * rate,
        ease: 'none',
      });
    });

    // ── Inner ambient float ──────────────────────────────────
    const innerBlobs = document.querySelectorAll<HTMLElement>('.contact-inner-ambient > div');
    if (innerBlobs.length) {
      gsap.to(innerBlobs, {
        y: -14,
        duration: 4.5,
        ease: 'sine.inOut',
        yoyo: true,
        repeat: -1,
        stagger: 1.8,
      });
    }

    // ── Submit button hover lift ─────────────────────────────
    const btn = document.querySelector<HTMLElement>('.contact-btn');
    if (btn) {
      btn.addEventListener('mouseenter', () =>
        gsap.to(btn, { y: -3, duration: 0.2, ease: 'power1.out' })
      );
      btn.addEventListener('mouseleave', () =>
        gsap.to(btn, { y: 0,  duration: 0.22, ease: 'power1.in' })
      );
    }

    // ── Card hover glow ──────────────────────────────────────
    const card = document.querySelector<HTMLElement>('.contact-card');
    if (card) {
      card.addEventListener('mouseenter', () =>
        gsap.to(card, {
          boxShadow: 'inset 0 1px 0 rgba(255,255,255,0.07), 0 36px 80px rgba(2,8,24,0.65), 0 0 32px rgba(123,142,200,0.08)',
          borderColor: 'rgba(123,142,200,0.36)',
          duration: 0.35,
          ease: 'power1.out',
        })
      );
      card.addEventListener('mouseleave', () =>
        gsap.to(card, {
          boxShadow: 'inset 0 1px 0 rgba(255,255,255,0.06), 0 30px 65px rgba(2,8,24,0.55)',
          borderColor: 'rgba(123,142,200,0.25)',
          duration: 0.38,
          ease: 'power1.inOut',
        })
      );
    }
  }

  // ── Label accent on focus (always active) ───────────────────
  document.querySelectorAll<HTMLElement>('.contact-field').forEach((field) => {
    const input = field.querySelector<HTMLInputElement | HTMLTextAreaElement>('input, textarea');
    const label = field.querySelector<HTMLElement>('.contact-label');
    if (!input || !label) return;
    input.addEventListener('focus', () => label.classList.add('is-focused'));
    input.addEventListener('blur',  () => label.classList.remove('is-focused'));
  });

  // ── Form submission: loading + success states ────────────────
  const form      = document.getElementById('contact-form')    as HTMLFormElement | null;
  const submit    = document.getElementById('contact-submit')  as HTMLButtonElement | null;
  const defEl     = document.getElementById('contact-btn-default')  as HTMLElement | null;
  const loadEl    = document.getElementById('contact-btn-loading')  as HTMLElement | null;
  const successEl = document.getElementById('contact-success')      as HTMLElement | null;

  if (form && submit && defEl && loadEl && successEl) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) { form.reportValidity(); return; }

      // → Loading
      submit.disabled = true;
      defEl.classList.add('hidden');
      loadEl.classList.remove('hidden');
      loadEl.classList.add('flex');

      // Simulated async send — swap with real fetch() when backend is ready
      await new Promise((r) => setTimeout(r, 1500));

      // → Success overlay
      successEl.style.pointerEvents = 'auto';
      if (!prefersReducedMotion) {
        gsap.to(successEl, { opacity: 1, duration: 0.5, ease: 'power2.out' });
        gsap.fromTo(
          Array.from(successEl.children),
          { y: 16, opacity: 0 },
          { y: 0,  opacity: 1, duration: 0.48, stagger: 0.1, ease: 'power2.out', delay: 0.12 }
        );
      } else {
        successEl.style.opacity = '1';
      }

      // → Auto-reset after 5 s
      setTimeout(() => {
        const reset = () => {
          form.reset();
          submit.disabled = false;
          defEl.classList.remove('hidden');
          loadEl.classList.add('hidden');
          loadEl.classList.remove('flex');
          successEl.style.opacity = '0';
          successEl.style.pointerEvents = 'none';
        };
        if (!prefersReducedMotion) {
          gsap.to(successEl, { opacity: 0, duration: 0.4, ease: 'power1.in', onComplete: reset });
        } else {
          reset();
        }
      }, 5000);
    });
  }
</script>
